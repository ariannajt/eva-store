# Copia este archivo a ".env" y completa con los datos de tu proyecto de Supabase
# (Configuracion del proyecto -> API, dentro de supabase.com)

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU-ANON-KEY

# Nombre, WhatsApp e Instagram de la tienda, se muestran en el catalogo publico
VITE_STORE_NAME=Mi Tienda de Computacion
VITE_STORE_WHATSAPP=584121234567
# Usuario de Instagram sin la arroba (opcional, si se deja vacio no se muestra el icono)
VITE_STORE_INSTAGRAM=
